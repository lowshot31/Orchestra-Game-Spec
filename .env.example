# Tutti Discord Bot 환경 설정
# 이 파일을 .env로 복사한 뒤 값을 채워주세요:  cp .env.example .env

# 필수: Discord Bot Token (https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=

# 에이전트 모드: mock | ollama | api
AGENT_MODE=mock

# 프리셋: fast_draft | balanced | deep_review
AGENT_PRESET=balanced

# Ollama 서버 주소 (AGENT_MODE=ollama일 때 필요)
# OLLAMA_BASE_URL=http://localhost:11434

# 에이전트별 모델 설정 (ollama 모드 기본값)
# DESIGNER_MODEL=qwen2.5-coder:7b-instruct
# REVIEWER_MODEL=qwen2.5-coder:7b-instruct
# CEO_MODEL=qwen3:8b
# SPEC_WRITER_MODEL=qwen2.5-coder:7b-instruct
# PROTOTYPE_MODEL=qwen2.5-coder:7b-instruct

# API 모드일 때 (선택)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=AI...

# GitHub PR 자동 생성 (선택, /tutti settings 및 /tutti apikey로도 설정 가능)
# GITHUB_GAME_REPO=owner/tutti-game-artifacts
# GITHUB_TOKEN=ghp_...
